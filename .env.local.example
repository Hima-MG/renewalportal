NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Used for metadataBase (canonical/OG URLs). Set to the deployed origin,
# e.g. https://renewal.civilezy.in — falls back to localhost in dev.
NEXT_PUBLIC_SITE_URL=

# Server-only — Firebase Admin SDK service account (used by app/api/track
# and app/api/admin/*). Never prefix these with NEXT_PUBLIC_; they must
# stay server-side.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Server-only — Cloudinary (used by app/api/upload). The API secret must
# never be exposed to the browser; cloud name and upload preset aren't
# secret, but are kept server-side too since only the server ever talks
# to Cloudinary directly.
CLOUDINARY_CLOUD_NAME=ihzutubd
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=renewal_uploads
