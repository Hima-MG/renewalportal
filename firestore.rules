rules_version = '2';

// Roles are issued as Firebase Auth custom claims:
// token.role == 'student' | 'finance' | 'admin'.
//
// Students have NO read access of any kind on renewal_requests — not a
// single get, not a list/query by phone or requestId, nothing. The only
// way a student can ever see their own renewal again is through the
// server-side /api/track route, which uses the Admin SDK (bypasses these
// rules entirely) and only returns data after it independently verifies
// requestId + trackingToken match. This is what prevents phone
// enumeration, request enumeration, collection scans, and direct
// document guessing — there is no client-reachable read path at all.
//
// Students also have NO write access of any kind on renewal_requests, and
// counters/* does not exist as a client-reachable collection at all.
// Creating a renewal (minting the sequential request ID from counters/*
// and writing the renewal_requests document) happens exclusively through
// app/api/create-renewal via the Admin SDK, which bypasses these rules
// entirely. See that route for why a client-side counters/* transaction
// was the wrong architecture to begin with.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isFinance() {
      return isSignedIn() && role() == 'finance';
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    function isStaff() {
      return isFinance() || isAdmin();
    }

    function isValidStatus(value) {
      return value in ['Pending', 'Approved', 'Rejected', 'Completed'];
    }

    // Mirrors the dashboard's Approve/Reject/Mark Completed button rules
    // server-side: Completed is terminal, Rejected can still be corrected
    // to Approved, Completed only follows Approved. A same-status update
    // (e.g. saving remarks) is always a no-op transition and allowed.
    function isValidStatusTransition(oldStatus, newStatus) {
      return newStatus == oldStatus
        || (newStatus == 'Approved' && oldStatus != 'Completed')
        || (newStatus == 'Rejected' && oldStatus != 'Completed')
        || (newStatus == 'Completed' && oldStatus == 'Approved');
    }

    match /renewal_requests/{requestId} {
      // No client create rule: every renewal_requests document is created
      // by app/api/create-renewal (Admin SDK) only. A client write rule
      // here — even one that validated every field — would still let a
      // student bypass the server's sequential ID generation and write a
      // document directly with a forged or colliding request ID, which is
      // the exact problem this architecture removes.
      allow read, delete: if isStaff();
      allow update: if isStaff()
        && isValidStatus(request.resource.data.status)
        && isValidStatusTransition(resource.data.status, request.resource.data.status);
    }

    // No counters/* match block: this collection is Admin SDK only. There
    // is no rule that grants any client (student, finance, or admin) read
    // or write access to it, so any client SDK request against counters/*
    // is denied by Firestore's default-deny — exactly the same as if the
    // collection didn't exist from the client's perspective.

    // Profile information only (name/email/role/isActive mirror). Never
    // used for authorization — that's always the custom claim. All writes
    // go through the Admin SDK (app/api/admin/users/*), which bypasses
    // these rules entirely, so this is intentionally fully locked down to
    // clients: not even an admin can write here directly from the browser.
    match /users/{uid} {
      allow read, write: if false;
    }
  }
}
